{
  "manifest_version": 3,
  "name": "Notion Job Saver (LinkedIn)",
  "version": "1.1.0",
  "description": "Adds a 'Save to Notion' button to LinkedIn jobs that saves the post to your Notion database.",
  "permissions": ["storage"],
  "host_permissions": ["https://api.notion.com/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://*.stepstone.de/*",
        "https://*.stepstone.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": { "default_title": "Notion Job Saver — settings" },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
