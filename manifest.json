{
  "manifest_version": 3,
  "name": "Notion Job Saver (LinkedIn)",
  "version": "1.2.0",
  "description": "Save jobs (LinkedIn, StepStone) to Notion and generate tailored cover letters.",
  "permissions": ["storage", "scripting"],
  "host_permissions": [
    "https://api.notion.com/*",
    "https://api.openai.com/*",
    "https://www.linkedin.com/*",
    "https://*.stepstone.de/*",
    "https://*.stepstone.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://*.stepstone.de/*",
        "https://*.stepstone.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": { "default_title": "Notion Job Saver — settings" },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
